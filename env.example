# Copy this file to .env and fill in your real keys

# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Google Custom Search API key — get from https://console.cloud.google.com/
GOOGLE_API_KEY=your-google-api-key-here

# Your Programmable Search Engine ID — from https://programmablesearchengine.google.com/
GOOGLE_CSE_ID=your-cse-id-here

# Path to your trained sklearn model
MODEL_PATH=grade_model.pkl
